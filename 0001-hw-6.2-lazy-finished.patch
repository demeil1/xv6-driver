 int
 handle_pagefault(addr_t va)
 {
-  // TODO: your code here
-  return 0;
+	struct file *f = 0;
+	addr_t region_start = 0;
+	uint64 file_sz = 0;
+
+	for(int i = 0; i < proc->mmapcount; i++){
+		addr_t start = proc->mmaps[i].start;
+		struct file *temp_f = proc->ofile[proc->mmaps[i].fd];
+
+		ilock(temp_f->ip);
+		uint64 sz = temp_f->ip->size;
+		iunlock(temp_f->ip);
+
+		if(va >= start && va < start + PGROUNDUP(sz)){
+			f = temp_f;
+			region_start = start;
+			file_sz = sz;
+			break;
+		}
+	}
+
+	if(f == 0) return -1;
+
+	addr_t fault_page = PGROUNDDOWN(va);
+	char *mem = kalloc();
+	if(mem == 0) return -1;
+	memset(mem, 0, PGSIZE);
+
+	if(mappages(proc->pgdir, (void*)fault_page, PGSIZE, V2P(mem), PTE_W|PTE_U) < 0){
+		kfree(mem);
+		return -1;
+	}
+
+	uint64 offset = fault_page - region_start;
+	uint n = PGSIZE;
+	if(offset + n > file_sz)
+		n = file_sz - offset;
+
+	ilock(f->ip);
+	if(readi(f->ip, mem, offset, n) < 0){
+		iunlock(f->ip);
+		return -1;
+	}
+	iunlock(f->ip);
+
+	return 0; 
 }
